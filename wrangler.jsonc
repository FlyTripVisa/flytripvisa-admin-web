{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/configuration/",
  "name": "flytripvisa-admin-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  
  "vars": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_APP_URL": "https://flytripvisa-admin-web.vercel.app/",
    "AI_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
    "CF_ACCOUNT_ID": "b73b80fa62deef032d3c08248cf2f30b"
  },
  
  "ai": { "binding": "AI" },
  
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flytripvisa_db",
      "database_id": "26c063fe-1868-44b1-9a8c-a68eecfa18e7"
    }
  ],
  
  "kv_namespaces": [
    {
      "binding": "KV_BINDING",
      "id": "cc79304937ff4daa9d6debae85da8be9"
    }
  ],
  {
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "83340a6d07c546aca205f2b46c4fc5ed"
    }
  ]
}
  "r2_buckets": [
    {
      "binding": "PROJECT_FILES",
      "bucket_name": "flytripvisaweb-project-files"
    }
  ],
  
  "assets": {
    "directory": ".open-next/assets",
    "not_found": "index.html"
  }
}
