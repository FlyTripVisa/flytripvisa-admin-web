# এআই মডেল এপিআই কী
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# রেডিস ডাটাবেস (স্টেট ও চ্যাট হিস্টোরি স্টোরেজ)
REDIS_URL=redis://your_redis_host:6379

# ১. টেলিগ্রাম কনফিগারেশন
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ২. উইচ্যাট কনফিগারেশন
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=your_wechat_token_for_verification
WECHAT_AES_KEY=your_wechat_encoding_aes_key

# ৩. হোয়াটসঅ্যাপ ক্লাউড এপিআই কনফিগারেশন
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_for_whatsapp_handshake

# ৪. ফেসবুক মেসেঞ্জার কনফিগারেশন
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_for_facebook_handshake
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ৫. গুগল চ্যাট কনফিগারেশন
GOOGLE_CHAT_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CHAT_PRIVATE_KEY=your_google_chat_service_account_private_key
GOOGLE_CHAT_CLIENT_EMAIL=your_google_chat_service_account_email